<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Secret access</title>
  </head>
  <body>
    <form action="/secretaccess" method="post">
      <h1>GUARDED DOOR</h1>
      <h3>You're one step way to get into our group!</h3>
      <label for="secret_code"
        >Enter the secret code to become a definitive member</label
      >
      <% if(locals.error) {%>
      <p style="color: red"><%=error[0].msg%></p>
      <% } %>
      <input
        type="password"
        name="code"
        id="secret_code"
        style="display: block"
      />
      <button>Submit</button>
    </form>
    <br />
    <form action="/logout" method="post">
      <button type="submit">Log out</button>
    </form>
  </body>
</html>
