<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign in</title>
  </head>
  <body>
    <form action="login" method="post">
      <label for="email">Enter your email</label>
      <input type="email" name="email" id="email" />

