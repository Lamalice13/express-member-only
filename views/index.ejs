<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Club House Lobby</title>
  </head>
  <body>
    <h1>Welcome to our club house !</h1>
    <% if (locals.user && locals.user.status === true) {%>
    <h2>You're connected, <%= user.firstname %> !</h2>
    <% } else if(locals.user && locals.user.status !== true) { %>
    <a href="/secretaccess">Go enter the secret access</a>
    <%} else { %>
    <a href="/signup">Sign up</a>
    <a href="/signin">Log in</a>
    <% } %>
  </body>
</html>
